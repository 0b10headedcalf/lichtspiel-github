{
  "name": "lichtspiel",
  "version": "0.1.0",
  "private": true,
  "description": "Lichtspiel — a standalone Ableton Live + Max for Live + p5.js audiovisual composition assistant. Reads Live session state, retrieves/morphs p5 visual scenes, played tactilely with monome grid + arc.",
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --reporter append-only dev",
    "dev:p5": "pnpm --filter @lichtspiel/p5-runtime dev",
    "dev:bridge": "pnpm --filter @lichtspiel/live-bridge dev",
    "dev:feeder": "node apps/live-bridge/demo-feeder.mjs",
    "dev:ml": "cd apps/ml-service && PYTHONPATH=src .venv/bin/python -m lichtspiel_ml.app",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r --no-bail typecheck",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "validate:schemas": "pnpm --filter @lichtspiel/schemas validate",
    "smoke:p5": "pnpm --filter @lichtspiel/p5-runtime smoke",
    "send": "pnpm --filter @lichtspiel/live-bridge cli",
    "dev:desktop": "pnpm --filter @lichtspiel/desktop start",
    "dmg:desktop": "pnpm --filter @lichtspiel/desktop dmg",
    "demo:mrt2": "pnpm --filter @lichtspiel/mrt2-bridge demo",
    "dev:mrt2": "pnpm --filter @lichtspiel/mrt2-bridge dev",
    "test:mrt2": "pnpm --filter @lichtspiel/mrt2-bridge test",
    "health:mrt2": "pnpm --filter @lichtspiel/mrt2-bridge health"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
