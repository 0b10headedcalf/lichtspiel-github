{
  "productName": "Lichtspiel",
  "version": "0.1.0",
  "identifier": "com.lichtspiel",
  "build": {
    "beforeDevCommand": "cd ../.. && pnpm --filter @lichtspiel/p5-runtime dev",
    "beforeBuildCommand": "cd ../.. && pnpm --filter @lichtspiel/p5-runtime build",
    "devUrl": "http://127.0.0.1:5273",
    "frontendDist": "../../p5-runtime/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Lichtspiel",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src 'self' ws: wss: http: https:; img-src 'self' data: blob:; media-src 'self';"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
