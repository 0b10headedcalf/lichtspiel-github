{
  "name": "@lichtspiel/mrt2-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Portable semantic-state bridge: Lichtspiel <-> Magenta RealTime 2 <-> Ableton Live.",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "demo": "tsx src/demo/runVerticalSlice.ts",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "health": "tsx src/index.ts --health",
    "live:check": "tsx scripts/liveLichtspielCheck.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "vitest": "^4.1.0"
  }
}
