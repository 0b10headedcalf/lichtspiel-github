# lichtspiel-mrt2-bridge configuration.
#
# The app runs with NO .env file at all — every value below has a safe default
# baked into src/config.ts. Copy this to `.env` only if you want to override.
# This is the ONLY file in the repo allowed to contain an absolute path.

# --- Bridge's own optional health/telemetry HTTP endpoint ---
BRIDGE_PORT=8787

# --- Lichtspiel (Mode 2) ---
# Connect to a REAL Lichtspiel live-bridge. Its real port is 7890.
ENABLE_LICHTSPIEL_CLIENT=false
LICHTSPIEL_WS_URL=ws://127.0.0.1:7890

# Bundled mock Lichtspiel WS server (used by the demo / mock mode). Kept on 8765
# so it never collides with a real Lichtspiel bridge running on 7890.
BRIDGE_MOCK_WS_HOST=127.0.0.1
BRIDGE_MOCK_WS_PORT=8765

# --- Magenta RealTime 2 (Mode 3) ---
ENABLE_MRT2_REAL=false
ENABLE_MOCK_MRT2=true
# MRT2's real environment variable. Models live at $MAGENTA_HOME/magenta-rt-v2/.
# Leave unset to fall back to ~/Documents/Magenta at runtime.
MAGENTA_HOME=/Users/zacharyscheffler/Documents/Magenta
# mrt2_small is real-time via the Python/MLX sidecar; mrt2_base is ~1.9x too slow
# that way (use the native C++ engine for base). Default = mrt2_small.
MRT2_MODEL=mrt2_small
# How the real adapter launches the Python sidecar (control+telemetry over stdio).
MRT2_SIDECAR_CMD=python3 sidecar/mrt2_sidecar.py

# --- Mock inputs ---
ENABLE_MOCK_ABLETON=true
ENABLE_MOCK_MONOME=true

# --- Transport clock (drives bar/beat quantization) ---
BRIDGE_BPM=120
BRIDGE_BEATS_PER_BAR=4

# --- Safety controller overrides (defaults shown) ---
SAFETY_MAX_PROMPT_UPS=4
SAFETY_MAX_PARAM_UPS=10
SAFETY_DEADBAND=0.03
SAFETY_SMOOTHING_MS=250
SAFETY_STALE_MS=2000
SAFETY_MAX_V2A_MOD_DEPTH=0.15
SAFETY_QUANTIZE=next_bar

# --- Logging / session ---
LOG_LEVEL=info
LOG_PRETTY=true
SESSION_ID=demo-session

# --- Fixtures ---
PROMPT_MAP_FILE=./src/demo/prompt-map.example.json
