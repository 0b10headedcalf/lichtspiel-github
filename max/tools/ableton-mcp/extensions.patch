+    def _get_scene_info(self):
+        """Session scenes + Arrangement cue points (locators) + transport state.
+        Read-only LOM introspection for Phase 5a retrieval testing."""
+        try:
+            scenes = []
+            for i, s in enumerate(self._song.scenes):
+                scenes.append({
+                    "index": i,
+                    "name": s.name,
+                    "is_triggered": s.is_triggered,
+                    "is_empty": s.is_empty
+                })
+            cue_points = []
+            for i, c in enumerate(self._song.cue_points):
+                cue_points.append({"index": i, "name": c.name, "time": c.time})
+            triggered = -1
+            for i, s in enumerate(self._song.scenes):
+                if s.is_triggered:
+                    triggered = i
