+            # Playing Session row: the first track with a playing clip slot (in a
+            # launched scene every track shares that row). Cheap early-exit scan in
+            # Python, so the feeder gets the scene in one get_scene_info call.
+            playing_scene = -1
+            try:
+                for tr in self._song.tracks:
+                    try:
+                        psi = tr.playing_slot_index
+                    except Exception:
