+@mcp.tool()
+def fire_scene(ctx: Context, scene_index: int) -> str:
+    """
+    Launch a Session-view scene by index (fires every clip in that scene row).
+    Drives the Lichtspiel scene-launch retrieval trigger.
+
+    Parameters:
+    - scene_index: The 0-based index of the scene to launch
+    """
+    try:
+        ableton = get_ableton_connection()
+        result = ableton.send_command("fire_scene", {"scene_index": scene_index})
+        return f"Launched scene {scene_index}: {result.get('name', '')}"
+    except Exception as e:
+        logger.error(f"Error firing scene: {str(e)}")
+        return f"Error firing scene: {str(e)}"
+
+@mcp.tool()
+def set_song_position(ctx: Context, time: float) -> str:
+    """
+    Move the Arrangement playhead to a beat position. Combined with start_playback,
+    this drives Lichtspiel locator-crossing tests (jump just before a locator, play).
+
+    Parameters:
+    - time: Song time in beats
+    """
+    try:
+        ableton = get_ableton_connection()
+        result = ableton.send_command("set_song_position", {"time": time})
+        return f"Set song position to {result.get('current_song_time', time)} beats"
+    except Exception as e:
+        logger.error(f"Error setting song position: {str(e)}")
+        return f"Error setting song position: {str(e)}"
+
+@mcp.tool()
+def back_to_arrangement(ctx: Context) -> str:
+    """
+    Clear the Session-clip override so Live plays the Arrangement (the "Back to
+    Arrangement" button). Needed to leave Session mode for locator testing.
+    """
+    try:
+        ableton = get_ableton_connection()
+        result = ableton.send_command("back_to_arrangement")
+        return f"Back to Arrangement (back_to_arranger={result.get('back_to_arranger')})"
+    except Exception as e:
+        logger.error(f"Error back_to_arrangement: {str(e)}")
+        return f"Error back_to_arrangement: {str(e)}"
+
+@mcp.tool()
+def get_scene_info(ctx: Context) -> str:
+    """
+    Get Session scenes (name, is_triggered, is_empty), Arrangement cue points
+    (locators: index, name, time), and transport state (is_playing,
+    current_song_time, back_to_arranger, tempo). Read-only LOM introspection.
+    """
+    try:
+        ableton = get_ableton_connection()
+        result = ableton.send_command("get_scene_info")
+        return json.dumps(result, indent=2)
+    except Exception as e:
+        logger.error(f"Error getting scene info: {str(e)}")
+        return f"Error getting scene info: {str(e)}"
+
