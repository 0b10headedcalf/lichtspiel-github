# Lichtspiel environment — copy to `.env` and adjust for your machine.
# Every value here has a safe in-code default; .env only overrides.

# ── Canvas / performance ─────────────────────────────────────────────
# Installation/performance target resolution. The dev runtime fits the
# canvas to the browser window; these are the documented output defaults.
LICHTSPIEL_CANVAS_W=2056
LICHTSPIEL_CANVAS_H=1260
LICHTSPIEL_TARGET_FPS=60

# ── Monome hardware ──────────────────────────────────────────────────
# The user owns TWO device classes; the app detects which is connected
# (via serialosc / device.attached) and adapts the p5 sketches + monome
# control mappings accordingly. None of these are "historical".
#
#   Grid 64  (8×8)   m64_0175    ── primary Lichtspiel target
#   Arc 2    (2 enc) m0000174    ── primary Lichtspiel target
#   Grid 128 (8×16)  m29496721   ── built most of the windchime-animation corpus
#   Arc 4    (4 enc) m0000007    ── built most of the windchime-animation corpus
#
# Primary (newer) devices — used when present:
LICHTSPIEL_GRID_SERIAL=m64_0175
LICHTSPIEL_ARC_SERIAL=m0000174
# Secondary devices the app should also recognise + adapt to:
LICHTSPIEL_GRID128_SERIAL=m29496721
LICHTSPIEL_ARC4_SERIAL=m0000007

# ── Service ports ────────────────────────────────────────────────────
# Node live-bridge WebSocket (browser p5 <-> bridge <-> Max/monome).
LICHTSPIEL_BRIDGE_WS_PORT=7890
# Node live-bridge HTTP status/diagnostics route.
LICHTSPIEL_BRIDGE_HTTP_PORT=7891
# Vite dev server for the p5 runtime.
LICHTSPIEL_P5_DEV_PORT=5273
# Python ML/retrieval sidecar.
LICHTSPIEL_ML_PORT=7892

# ── OSC: Max for Live <-> bridge ─────────────────────────────────────
# Max-side OSC send/recv used by the LichtspielHub device.
LICHTSPIEL_OSC_MAX_TO_BRIDGE_PORT=7400
LICHTSPIEL_OSC_BRIDGE_TO_MAX_PORT=7401

# ── OSC: serialosc <-> bridge (monome grid + arc) ────────────────────
# serialosc daemon port. The bridge discovers + configures devices via this.
LICHTSPIEL_SERIALOSC_PORT=12002
# Port the app/bridge binds + listens on for monome OSC (set on each device via
# /sys/port); device events arrive here and LED writes go back out from here.
LICHTSPIEL_OSC_APP_PORT=13333
# OSC address prefix the bridge sets on each device (/sys/prefix). See docs/monome.md.
LICHTSPIEL_OSC_PREFIX=/lichtspiel
# LED flush + arc-delta coalesce rate (Hz). Higher = snappier, more OSC traffic.
LICHTSPIEL_LED_HZ=30
# Set to 1 to log inbound serialosc OSC (discovery + device events) for debugging.
LICHTSPIEL_DEBUG_OSC=0
# Auto-restart the serialosc daemon when a known monome is present at USB but the
# daemon won't enumerate it (recovers the Arc 4 FTDI clone on re-plug). Set 0 to disable.
LICHTSPIEL_SERIALOSC_RECOVER=1
# Command used for that recovery (default below). Override if not using Homebrew.
LICHTSPIEL_SERIALOSC_RESTART_CMD=brew services restart serialosc

# ── Bridge binding ───────────────────────────────────────────────────
# Loopback-only by default (security). Change only for a trusted LAN.
LICHTSPIEL_BIND_HOST=127.0.0.1

# ── ML / retrieval (later phases) ────────────────────────────────────
# Embedding backend: "metadata" (no model), "midi", or "embed".
LICHTSPIEL_RETRIEVAL_MODE=metadata
LICHTSPIEL_ML_CACHE_DIR=apps/ml-service/.cache
# Phase 7 — embedding blend weight (0..1) when RETRIEVAL_MODE=embed:
#   score = (1-W)*metadata + W*audio_cosine.  Higher W = trust the sound more.
LICHTSPIEL_EMBED_WEIGHT=0.5
# Which SAME autoencoder the SA3 path loads (same-s = CPU / Apple Silicon).
LICHTSPIEL_SAME_MODEL=same-s
# Bridge: POST each live.state to the ml-service and relay its scene to p5.
# Set 0 to keep the runtime purely manual / CLI-driven (no auto-retrieval).
LICHTSPIEL_ML_AUTORETRIEVE=1
# Generative-audio loop — AudioInserter Remote Script socket (SA3 → Ableton clip).
LICHTSPIEL_AUDIOINSERTER_PORT=9129

# ── Generative track (G1/G3, BUILD-TIME ONLY — never read at runtime) ─
# audio -> CLAP vibe -> Claude codegen. Install: pip install -e 'apps/ml-service[generate]'
ANTHROPIC_API_KEY=
# Codegen model (defaults to claude-sonnet-4-6 for speed/cost).
LICHTSPIEL_CODEGEN_MODEL=claude-sonnet-4-6
# Manual-export watch folder: the Discover button (no explicit path) generates
# from the NEWEST audio clip here. Export from Ableton into this folder, click ✶.
LICHTSPIEL_AUDIO_WATCH_DIR=demo/captures
