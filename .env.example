# Lichtspiel environment — copy to `.env` and adjust for your machine.
# Every value here has a safe in-code default; .env only overrides.

# ── Canvas / performance ─────────────────────────────────────────────
# Installation/performance target resolution. The dev runtime fits the
# canvas to the browser window; these are the documented output defaults.
LICHTSPIEL_CANVAS_W=2056
LICHTSPIEL_CANVAS_H=1260
LICHTSPIEL_TARGET_FPS=60

# ── Monome hardware (see spec §3) ────────────────────────────────────
# Current user hardware. Older Windchime/Processing serials
# (m29496721 / m0000007) are historical references only — do not use.
LICHTSPIEL_GRID64_SERIAL=m64_0175
LICHTSPIEL_ARC2_SERIAL=m0000174

# ── Service ports ────────────────────────────────────────────────────
# Node live-bridge WebSocket (browser p5 <-> bridge <-> Max/monome).
LICHTSPIEL_BRIDGE_WS_PORT=7890
# Node live-bridge HTTP status/diagnostics route.
LICHTSPIEL_BRIDGE_HTTP_PORT=7891
# Vite dev server for the p5 runtime.
LICHTSPIEL_P5_DEV_PORT=5273
# Python ML/retrieval sidecar.
LICHTSPIEL_ML_PORT=7892

# ── OSC (Max for Live <-> bridge, and serialosc fallback) ────────────
# Max-side OSC send/recv used by node_bridge.maxpat.
LICHTSPIEL_OSC_MAX_TO_BRIDGE_PORT=7400
LICHTSPIEL_OSC_BRIDGE_TO_MAX_PORT=7401
# serialosc (monome). The bridge auto-discovers devices via this port.
LICHTSPIEL_SERIALOSC_PORT=12002

# ── Bridge binding ───────────────────────────────────────────────────
# Loopback-only by default (security). Change only for a trusted LAN.
LICHTSPIEL_BIND_HOST=127.0.0.1

# ── ML / retrieval (later phases) ────────────────────────────────────
# Embedding backend: "metadata" (no model), "midi", or "embed".
LICHTSPIEL_RETRIEVAL_MODE=metadata
LICHTSPIEL_ML_CACHE_DIR=apps/ml-service/.cache
